{
  "model": "opus[1m]",
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "theme": "dark",
  "statusLine": {
    "type": "command",
    "command": "<STATUSLINE_PATH> super",
    "padding": 2
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "dotnet@dotnet-agent-skills": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "dotnet-agent-skills": { "source": { "source": "github", "repo": "dotnet/skills" } },
    "openai-codex": { "source": { "source": "github", "repo": "openai/codex-plugin-cc" } }
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "<HOOK_PATH>" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "paplay <SOUND_PATH> >/dev/null 2>&1", "async": true } ] }
    ],
    "Notification": [
      { "hooks": [ { "type": "command", "command": "paplay <SOUND_PATH> >/dev/null 2>&1", "async": true } ] }
    ]
  }
}
